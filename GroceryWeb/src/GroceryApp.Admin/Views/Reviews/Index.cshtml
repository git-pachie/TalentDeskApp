@model List<ReviewModel>
@{
    ViewData["Title"] = "Reviews";
}

<div class="page-header">
    <div>
        <h2><i class="bi bi-star-fill me-2 text-primary"></i>Reviews</h2>
        <p class="text-muted mb-0" style="font-size: 0.85rem;">Moderate customer reviews</p>
    </div>
</div>

<div class="card data-card">
    <table class="table data-table">
        <thead>
            <tr>
                <th>Customer</th>
                <th>Rating</th>
                <th>Comment</th>
                <th>Photos</th>
                <th>Date</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Count > 0)
            {
                @foreach (var review in Model)
                {
                    <tr>
                        <td class="fw-semibold">@review.UserName</td>
                        <td>
                            <div class="d-flex align-items-center gap-1">
                                @for (int i = 0; i < 5; i++)
                                {
                                    <i class="bi @(i < review.Rating ? "bi-star-fill text-warning" : "bi-star text-muted")" style="font-size: 0.85rem;"></i>
                                }
                                <span class="text-muted ms-1" style="font-size: 0.8rem;">(@review.Rating)</span>
                            </div>
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(review.Comment))
                            {
                                <span title="@review.Comment">
                                    @(review.Comment.Length > 80 ? review.Comment[..80] + "..." : review.Comment)
                                </span>
                            }
                            else
                            {
                                <span class="text-muted fst-italic">No comment</span>
                            }
                        </td>
                        <td>
                            @if (review.Photos.Count > 0)
                            {
                                <span class="badge bg-info-subtle text-info">
                                    <i class="bi bi-image me-1"></i>@review.Photos.Count
                                </span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="text-muted">@review.CreatedAt.ToString("MMM dd, yyyy")</td>
                        <td class="text-end">
                            <form asp-action="Delete" asp-route-id="@review.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete this review? This cannot be undone.');">
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete review">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6">
                        <div class="empty-state">
                            <i class="bi bi-star"></i>
                            <p>No reviews yet.</p>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
