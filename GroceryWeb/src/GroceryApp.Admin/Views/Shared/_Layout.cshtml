<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - GroceryApp Admin</title>

    <!-- Google Fonts - Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Vendor CSS Files -->
    <link href="~/vendors/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/vendors/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    <link href="~/vendors/phosphor-icons/phosphor-icons.css" rel="stylesheet">

    <!-- Template Main CSS File -->
    <link href="~/css/easyadmin-full.css?v=@DateTime.Now.Ticks" rel="stylesheet">

    <!-- GroceryApp Green Theme Override -->
    <link href="~/css/grocery-theme.css?v=@DateTime.Now.Ticks" rel="stylesheet">
</head>
<body>
    @{
        var sessionRoles = (Context.Session.GetString("UserRoles") ?? string.Empty)
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        var canManageUsers = sessionRoles.Contains("Admin");
    }
    @if (Context.Session.GetString("JwtToken") != null)
    {
        <!-- Header -->
        <header class="header">
            <!-- Header Left -->
            <div class="header-left">
                <a href="/" class="header-logo">
                    <span style="display:inline-flex;align-items:center;justify-content:center;width:32px;height:32px;background:linear-gradient(135deg,#059669,#047857);border-radius:8px;margin-right:4px;">
                        <i class="bi bi-cart3" style="color:#fff;font-size:1rem;"></i>
                    </span>
                    <span>GroceryApp</span>
                </a>
                <button class="sidebar-toggle" title="Toggle Sidebar">
                    <i class="bi bi-list"></i>
                </button>
            </div>

            <!-- Header Search (Desktop) -->
            <div class="header-search">
                <form class="search-form collapsed" method="GET">
                    <button type="button" class="search-toggle-btn"><i class="bi bi-search"></i></button>
                    <input type="search" name="q" placeholder="Search..." autocomplete="off">
                </form>
            </div>

            <!-- Header Right -->
            <div class="header-right">
                <div class="header-actions-desktop">
                    <!-- Theme Toggle -->
                    <button class="header-action theme-toggle" title="Toggle Theme">
                        <i class="bi bi-moon icon-dark"></i>
                        <i class="bi bi-sun icon-light"></i>
                    </button>

                    <!-- Fullscreen Toggle -->
                    <button class="header-action fullscreen-toggle" title="Fullscreen">
                        <i class="bi bi-fullscreen icon-enter"></i>
                        <i class="bi bi-fullscreen-exit icon-exit"></i>
                    </button>

                    <!-- User Dropdown -->
                    <div class="header-action dropdown user-dropdown">
                        <button class="dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                            <img src="https://ui-avatars.com/api/?name=@(Context.Session.GetString("UserName")?.Replace(" ", "+") ?? "Admin")&background=059669&color=fff" alt="User" class="avatar">
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li class="dropdown-header">
                                <img src="https://ui-avatars.com/api/?name=@(Context.Session.GetString("UserName")?.Replace(" ", "+") ?? "Admin")&background=059669&color=fff" alt="User" class="user-avatar">
                                <div class="user-info">
                                    <h6>@Context.Session.GetString("UserName")</h6>
                                    <span>@(sessionRoles.FirstOrDefault() ?? "User")</span>
                                </div>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item dropdown-item-danger" asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right"></i> Sign Out</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </header>

        <!-- Sidebar -->
        <aside class="sidebar">
            <!-- Sidebar Header -->
            <div class="sidebar-header">
                <a href="/" class="sidebar-logo">
                    <span style="display:inline-flex;align-items:center;justify-content:center;width:36px;height:36px;background:linear-gradient(135deg,#059669,#047857);border-radius:10px;flex-shrink:0;">
                        <i class="bi bi-cart3" style="color:#fff;font-size:1.1rem;"></i>
                    </span>
                    <span class="sidebar-logo-text">
                        <span class="sidebar-logo-name">GroceryApp</span>
                        <span class="sidebar-logo-tagline">Admin Panel</span>
                    </span>
                </a>
                <button class="sidebar-close">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <!-- Sidebar Navigation -->
            <nav class="sidebar-nav">
                <ul class="nav-menu">
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")" asp-controller="Dashboard" asp-action="Index" data-tooltip="Dashboard">
                            <i class="ph-duotone ph-squares-four"></i>
                            <span>Dashboard</span>
                        </a>
                    </li>

                    <!-- Catalog Section -->
                    <li class="nav-heading"><span>Catalog</span></li>

                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Products" ? "active" : "")" asp-controller="Products" asp-action="Index" data-tooltip="Products">
                            <i class="ph-duotone ph-package"></i>
                            <span>Products</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Categories" ? "active" : "")" asp-controller="Categories" asp-action="Index" data-tooltip="Categories">
                            <i class="ph-duotone ph-tag"></i>
                            <span>Categories</span>
                        </a>
                    </li>

                    <!-- Orders & Payments -->
                    <li class="nav-heading"><span>Orders</span></li>

                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Orders" ? "active" : "")" asp-controller="Orders" asp-action="Index" data-tooltip="Orders">
                            <i class="ph-duotone ph-shopping-cart"></i>
                            <span>Orders</span>
                        </a>
                    </li>

                    <!-- Marketing -->
                    <li class="nav-heading"><span>Marketing</span></li>

                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Vouchers" ? "active" : "")" asp-controller="Vouchers" asp-action="Index" data-tooltip="Vouchers">
                            <i class="ph-duotone ph-ticket"></i>
                            <span>Vouchers</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "TodayDeals" ? "active" : "")" asp-controller="TodayDeals" asp-action="Index" data-tooltip="Today's Deals">
                            <i class="ph-duotone ph-lightning"></i>
                            <span>Today's Deals</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "SpecialOffers" ? "active" : "")" asp-controller="SpecialOffers" asp-action="Index" data-tooltip="Special Offers">
                            <i class="ph-duotone ph-megaphone"></i>
                            <span>Special Offers</span>
                        </a>
                    </li>

                    <!-- Users -->
                    <li class="nav-heading"><span>Users</span></li>

                    @if (canManageUsers)
                    {
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" ? "active" : "")" asp-controller="Users" asp-action="Index" data-tooltip="Users">
                                <i class="ph-duotone ph-users"></i>
                                <span>Users</span>
                            </a>
                        </li>
                    }
                </ul>
            </nav>
        </aside>

        <!-- Sidebar Overlay (Mobile) -->
        <div class="sidebar-overlay"></div>

        <!-- Main Content -->
        <main class="main">
            <div class="main-content">
                @RenderBody()
            </div>

            <!-- Footer -->
            <footer class="footer">
                <div class="footer-content">
                    <div class="footer-copyright">
                        &copy; @DateTime.Now.Year <a href="#">GroceryApp</a>. All Rights Reserved.
                    </div>
                </div>
            </footer>
        </main>

        <!-- Back to Top -->
        <a href="#" class="back-to-top">
            <i class="bi bi-arrow-up"></i>
        </a>
    }
    else
    {
        <div class="container">
            @RenderBody()
        </div>
    }

    <!-- Vendor JS Files -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/vendors/bootstrap/js/bootstrap.bundle.min.js"></script>

    <!-- Template JS Files -->
    <script src="~/easyadmin-assets/js/theme.js"></script>
    <script src="~/easyadmin-assets/js/main.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
