@model OrderModel
@{
    ViewData["Title"] = $"Order {Model.OrderNumber}";
    var initials = string.Concat(
        (Model.CustomerName ?? "")
        .Split(' ', StringSplitOptions.RemoveEmptyEntries)
        .Take(2).Select(w => w[0]));
    if (string.IsNullOrEmpty(initials)) initials = "?";
}

<!-- ===== PAGE HEADER ===== -->
<div class="page-header">
    <div>
        <h2 class="mb-0"><i class="bi bi-receipt me-2 text-primary"></i>@Model.OrderNumber</h2>
        <p class="text-muted mb-0 mt-1" style="font-size:0.85rem;">
            <i class="bi bi-calendar3 me-1"></i>@Model.CreatedAt.ToString("MMMM dd, yyyy 'at' hh:mm tt")
        </p>
    </div>
    <div class="d-flex gap-2 flex-wrap align-items-center">
        <a asp-action="ExportPdf" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-danger" target="_blank">
            <i class="bi bi-file-earmark-pdf me-1"></i>PDF
        </a>
        <a asp-action="Print" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-secondary" target="_blank">
            <i class="bi bi-printer me-1"></i>Print
        </a>
        <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#sendEmailModal">
            <i class="bi bi-envelope me-1"></i>Email
        </button>
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<!-- ===== ALERTS ===== -->
@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@error
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- ===== QUICK SEARCH ===== -->
<div class="card form-card mb-3">
    <div class="card-body py-2 px-3">
        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-search text-muted flex-shrink-0"></i>
            <div class="position-relative flex-fill" style="max-width:500px;">
                <input type="text" id="quickSearch" class="form-control form-control-sm border-0 shadow-none ps-0"
                       placeholder="Jump to another order — search by order #, customer name or email..."
                       autocomplete="off" style="font-size:0.85rem;background:transparent;" />
                <span id="quickSearchSpinner" class="position-absolute top-50 end-0 translate-middle-y pe-2" style="display:none;">
                    <div class="spinner-border spinner-border-sm text-muted" style="width:13px;height:13px;"></div>
                </span>
                <div id="quickSearchDropdown"
                     class="position-absolute bg-white border rounded-3 shadow"
                     style="top:calc(100% + 6px);left:0;right:0;z-index:1055;display:none;max-height:300px;overflow-y:auto;">
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ===== MAIN LAYOUT ===== -->
<div class="row g-3 align-items-start">

    <!-- ========== LEFT COL: Items + Remarks + Reviews ========== -->
    <div class="col-xl-8 col-lg-7">

        <!-- Order Items -->
        <div class="card data-card mb-3">
            <div class="card-header d-flex align-items-center justify-content-between">
                <h6 class="mb-0 fw-bold"><i class="bi bi-bag me-2 text-primary"></i>Order Items</h6>
                <span class="badge bg-secondary">@Model.Items.Count item(s)</span>
            </div>
            <div class="table-responsive">
                <table class="table data-table mb-0">
                    <thead>
                        <tr>
                            <th style="width:50%;">Product</th>
                            <th class="text-end">Unit Price</th>
                            <th class="text-center">Qty</th>
                            <th class="text-end">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr style="vertical-align:middle;">
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        @if (!string.IsNullOrEmpty(item.ProductImageUrl))
                                        {
                                            <img src="@ImageProxyUrl(item.ProductImageUrl)" alt="@item.ProductName"
                                                 class="rounded flex-shrink-0"
                                                 style="width:42px;height:42px;object-fit:cover;"
                                                 onerror="this.onerror=null;this.src='/images/default-product.svg';" />
                                        }
                                        else
                                        {
                                            <div class="rounded flex-shrink-0 d-flex align-items-center justify-content-center bg-light"
                                                 style="width:42px;height:42px;">
                                                <i class="bi bi-box text-muted"></i>
                                            </div>
                                        }
                                        <div>
                                            <div class="fw-semibold" style="font-size:0.9rem;">@item.ProductName</div>
                                            @if (!string.IsNullOrEmpty(item.Remarks))
                                            {
                                                <div class="text-muted mt-1" style="font-size:0.78rem;">
                                                    <i class="bi bi-chat-left-text me-1"></i>@item.Remarks
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td class="text-end align-middle" style="font-size:0.9rem;">₱@item.UnitPrice.ToString("N2")</td>
                                <td class="text-center align-middle">
                                    <span class="badge bg-light text-dark border px-2">@item.Quantity</span>
                                </td>
                                <td class="text-end align-middle fw-semibold" style="font-size:0.9rem;">₱@item.TotalPrice.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Payment Summary -->
            <div class="card-footer bg-white px-4 py-3">
                <div class="row justify-content-end">
                    <div class="col-sm-6 col-md-5">
                        <div class="d-flex justify-content-between py-1 border-bottom">
                            <span class="text-muted" style="font-size:0.85rem;">Subtotal</span>
                            <span style="font-size:0.85rem;">₱@Model.SubTotal.ToString("N2")</span>
                        </div>
                        @if (Model.DiscountAmount > 0)
                        {
                            <div class="d-flex justify-content-between py-1 border-bottom text-success">
                                <span style="font-size:0.85rem;">
                                    <i class="bi bi-tag me-1"></i>Discount
                                    @if (!string.IsNullOrEmpty(Model.VoucherCode))
                                    {
                                        <span class="badge bg-success-subtle text-success ms-1" style="font-size:0.7rem;">@Model.VoucherCode</span>
                                    }
                                </span>
                                <span style="font-size:0.85rem;">-₱@Model.DiscountAmount.ToString("N2")</span>
                            </div>
                        }
                        <div class="d-flex justify-content-between py-1 border-bottom">
                            <span class="text-muted" style="font-size:0.85rem;">Delivery Fee</span>
                            <span style="font-size:0.85rem;">₱@Model.DeliveryFee.ToString("N2")</span>
                        </div>
                        <div class="d-flex justify-content-between py-1 border-bottom">
                            <span class="text-muted" style="font-size:0.85rem;">Platform Fee</span>
                            <span style="font-size:0.85rem;">₱@Model.PlatformFee.ToString("N2")</span>
                        </div>
                        <div class="d-flex justify-content-between py-1 border-bottom">
                            <span class="text-muted" style="font-size:0.85rem;">Other Charges</span>
                            <span style="font-size:0.85rem;">₱@Model.OtherCharges.ToString("N2")</span>
                        </div>
                        <div class="d-flex justify-content-between pt-2">
                            <span class="fw-bold">Total</span>
                            <span class="fw-bold fs-5 text-primary">₱@Model.TotalAmount.ToString("N2")</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Order Remarks -->
        @if (!string.IsNullOrEmpty(Model.Notes))
        {
            <div class="card form-card mb-3">
                <div class="card-body">
                    <h6 class="fw-bold mb-2">
                        <i class="bi bi-chat-left-text me-2 text-primary"></i>Order Remarks
                    </h6>
                    <p class="text-muted mb-0" style="font-size:0.9rem;">@Model.Notes</p>
                </div>
            </div>
        }

        <!-- Ratings & Reviews -->
        @if (Model.Reviews.Count > 0)
        {
            <div class="card data-card mb-3">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-star me-2 text-warning"></i>Ratings &amp; Reviews</h6>
                    <span class="badge bg-warning text-dark">@Model.Reviews.Count review(s)</span>
                </div>
                <div class="card-body p-3">
                    @foreach (var review in Model.Reviews)
                    {
                        <div class="border rounded-3 p-3 mb-3 bg-light bg-opacity-50">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <span class="fw-semibold" style="font-size:0.9rem;">@review.UserName</span>
                                </div>
                                <span class="text-muted" style="font-size:0.78rem;">@review.CreatedAt.ToString("MMM dd, yyyy")</span>
                            </div>
                            <div class="mb-2">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <i class="bi @(i <= review.Rating ? "bi-star-fill text-warning" : "bi-star text-muted")" style="font-size:0.85rem;"></i>
                                }
                                <span class="ms-1 text-muted" style="font-size:0.8rem;">@review.Rating / 5</span>
                            </div>
                            @if (!string.IsNullOrEmpty(review.Comment))
                            {
                                <p class="mb-2 text-muted" style="font-size:0.88rem;">@review.Comment</p>
                            }
                            @if (review.Photos.Count > 0)
                            {
                                var reviewBase = ViewBag.ReviewImageBase as string ?? "";
                                string ResolvePhoto(string url) =>
                                    ImageProxyUrl(url.StartsWith("http") ? url : $"{reviewBase.TrimEnd('/')}{url}");
                                <div class="d-flex flex-wrap gap-2 mt-2">
                                    @foreach (var photo in review.Photos)
                                    {
                                        var fullUrl = ResolvePhoto(photo.PhotoUrl);
                                        <img src="@fullUrl" alt="Review photo" loading="lazy"
                                             class="rounded-2 border review-photo-thumb"
                                             style="width:72px;height:72px;object-fit:cover;cursor:pointer;"
                                             data-photos="@string.Join(",", review.Photos.Select(p => ResolvePhoto(p.PhotoUrl)))"
                                             data-index="@review.Photos.IndexOf(photo)"
                                             onclick="openPhotoCarousel(this)" />
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <!-- ========== RIGHT COL: Sidebar ========== -->
    <div class="col-xl-4 col-lg-5">

        <!-- Customer -->
        <div class="card form-card mb-3">
            <div class="card-header">
                <h6 class="mb-0 fw-bold"><i class="bi bi-person me-2 text-primary"></i>Customer</h6>
            </div>
            <div class="card-body">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold flex-shrink-0"
                         style="width:44px;height:44px;font-size:0.9rem;background:linear-gradient(135deg,#6366f1,#8b5cf6);">
                        @initials
                    </div>
                    <div class="min-w-0">
                        @if (Model.UserId != Guid.Empty && !string.IsNullOrEmpty(Model.CustomerName))
                        {
                            <a asp-controller="Users" asp-action="Detail" asp-route-id="@Model.UserId"
                               class="fw-semibold text-decoration-none d-block text-truncate">@Model.CustomerName</a>
                        }
                        else
                        {
                            <span class="fw-semibold text-muted">Guest / Unknown</span>
                        }
                        <span class="badge bg-light text-muted border" style="font-size:0.7rem;">Customer</span>
                    </div>
                </div>
                <div class="vstack gap-2">
                    @if (!string.IsNullOrEmpty(Model.CustomerEmail))
                    {
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-envelope text-muted flex-shrink-0" style="width:16px;"></i>
                            <a href="mailto:@Model.CustomerEmail"
                               class="text-muted text-decoration-none text-truncate"
                               style="font-size:0.85rem;">@Model.CustomerEmail</a>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.CustomerPhone))
                    {
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-telephone text-muted flex-shrink-0" style="width:16px;"></i>
                            <span class="text-muted" style="font-size:0.85rem;">@Model.CustomerPhone</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Order Status -->
        <div class="card form-card mb-3">
            <div class="card-header">
                <h6 class="mb-0 fw-bold"><i class="bi bi-flag me-2 text-primary"></i>Order Status</h6>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <span class="badge @GetStatusBadge(Model.Status) px-3 py-2 fs-6 w-100 text-center d-block">
                        @Model.Status
                    </span>
                </div>
                <form asp-action="UpdateStatus" asp-route-id="@Model.Id" method="post">
                    <label class="form-label fw-semibold mb-1" style="font-size:0.82rem;">Change Status</label>
                    <select name="status" class="form-select form-select-sm mb-2">
                        @foreach (var s in new[] { "Pending","Paid","Processing","Delivered","Cancelled" })
                        {
                            <option value="@s" selected="@(Model.Status == s)">@s</option>
                        }
                    </select>
                    <button type="submit" class="btn btn-primary btn-sm w-100">
                        <i class="bi bi-arrow-repeat me-1"></i>Update Status
                    </button>
                </form>
            </div>
        </div>

        <!-- Payment -->
        @if (Model.Payment is not null)
        {
            <div class="card form-card mb-3">
                <div class="card-header">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-credit-card me-2 text-primary"></i>Payment</h6>
                </div>
                <div class="card-body">
                    <div class="vstack gap-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted" style="font-size:0.85rem;">Method</span>
                            <span class="fw-medium" style="font-size:0.85rem;">@Model.Payment.Method</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted" style="font-size:0.85rem;">Status</span>
                            <span class="badge @(Model.Payment.Status == "Paid" ? "bg-success" : "bg-warning text-dark")">
                                @Model.Payment.Status
                            </span>
                        </div>
                        @if (Model.Payment.PaidAt.HasValue)
                        {
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="text-muted" style="font-size:0.85rem;">Paid at</span>
                                <span style="font-size:0.85rem;">@Model.Payment.PaidAt.Value.ToString("MMM dd, yyyy HH:mm")</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- Delivery Address -->
        @if (Model.Address is not null)
        {
            <div class="card form-card mb-3">
                <div class="card-header">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-geo-alt me-2 text-primary"></i>Delivery Address</h6>
                </div>
                <div class="card-body">
                    <div class="mb-2">
                        <span class="badge bg-primary-subtle text-primary mb-1">@Model.Address.Label</span>
                        <div class="fw-medium" style="font-size:0.88rem;">@Model.Address.Street</div>
                        <div class="text-muted" style="font-size:0.85rem;">
                            @Model.Address.City, @Model.Address.Province @Model.Address.ZipCode
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Address.ContactNumber))
                    {
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <i class="bi bi-telephone text-muted flex-shrink-0" style="width:14px;font-size:0.8rem;"></i>
                            <span style="font-size:0.85rem;">@Model.Address.ContactNumber</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Address.DeliveryInstructions))
                    {
                        <div class="d-flex align-items-start gap-2 mb-2">
                            <i class="bi bi-info-circle text-muted flex-shrink-0 mt-1" style="width:14px;font-size:0.8rem;"></i>
                            <span class="text-muted" style="font-size:0.85rem;">@Model.Address.DeliveryInstructions</span>
                        </div>
                    }
                    @if (Model.Address.Latitude.HasValue && Model.Address.Longitude.HasValue)
                    {
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <i class="bi bi-pin-map text-muted flex-shrink-0" style="width:14px;font-size:0.8rem;"></i>
                            <span class="text-muted" style="font-size:0.78rem;">
                                @Model.Address.Latitude.Value.ToString("F5"), @Model.Address.Longitude.Value.ToString("F5")
                            </span>
                        </div>
                        <a href="https://www.google.com/maps?q=@Model.Address.Latitude.Value,@Model.Address.Longitude.Value"
                           target="_blank" rel="noopener noreferrer"
                           class="btn btn-outline-primary btn-sm w-100">
                            <i class="bi bi-map me-1"></i>View on Map
                        </a>
                    }
                </div>
            </div>
        }

        <!-- Status Timeline -->
        @if (Model.StatusHistory.Count > 0)
        {
            <div class="card form-card mb-3">
                <div class="card-header">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-clock-history me-2 text-primary"></i>Status Timeline</h6>
                </div>
                <div class="card-body pb-2">
                    <div style="padding-left:22px;">
                        @foreach (var entry in Model.StatusHistory)
                        {
                            var isLast = entry == Model.StatusHistory.Last();
                            <div class="position-relative mb-3">
                                <!-- dot -->
                                <div class="position-absolute rounded-circle"
                                     style="left:-22px;top:3px;width:11px;height:11px;
                                            background:@GetTimelineDot(entry.Status);
                                            border:2px solid #fff;
                                            box-shadow:0 0 0 2px @GetTimelineDot(entry.Status);"></div>
                                <!-- connector line -->
                                @if (!isLast)
                                {
                                    <div class="position-absolute"
                                         style="left:-17px;top:16px;width:2px;height:calc(100% + 8px);background:#e5e7eb;"></div>
                                }
                                <div class="fw-semibold" style="font-size:0.85rem;">@entry.Status</div>
                                <div class="text-muted" style="font-size:0.75rem;">
                                    @entry.CreatedAt.ToString("MMM dd, yyyy HH:mm") &middot; @entry.CreatedBy
                                </div>
                                @if (!string.IsNullOrEmpty(entry.Notes))
                                {
                                    <div class="text-muted mt-1" style="font-size:0.78rem;">@entry.Notes</div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

    </div><!-- /right col -->
</div><!-- /row -->

<!-- ===== SEND EMAIL MODAL ===== -->
<div class="modal fade" id="sendEmailModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="SendEmail" asp-route-id="@Model.Id" method="post">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold">
                        <i class="bi bi-envelope me-2 text-primary"></i>Send Order Invoice
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body pt-3">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Recipient Email <span class="text-danger">*</span>
                        </label>
                        <input type="email" name="toEmail" class="form-control" required
                               value="@Model.CustomerEmail"
                               placeholder="customer@example.com" />
                        <div class="form-text">
                            <i class="bi bi-paperclip me-1"></i>PDF invoice will be attached automatically.
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Message <span class="text-muted fw-normal">(optional)</span>
                        </label>
                        <textarea name="message" class="form-control" rows="3"
                                  placeholder="Add a personal note..."></textarea>
                    </div>
                    <div class="rounded-3 p-3 border" style="background:#f9fafb;">
                        <div class="fw-semibold mb-1" style="font-size:0.85rem;">Order Summary</div>
                        <div class="text-muted" style="font-size:0.82rem;">
                            <span class="me-2">@Model.OrderNumber</span>
                            <span class="me-2">·</span>
                            <span class="me-2">@Model.Items.Count item(s)</span>
                            <span class="me-2">·</span>
                            <span class="me-2">₱@Model.TotalAmount.ToString("N2")</span>
                            <span class="me-2">·</span>
                            <span class="badge @GetStatusBadge(Model.Status)" style="font-size:0.7rem;">@Model.Status</span>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-send me-1"></i>Send Invoice
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Photo Carousel Modal -->
<div class="modal fade" id="photoCarouselModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content bg-dark border-0">
            <div class="modal-header border-0 pb-0">
                <span id="photoCarouselCounter" class="text-white-50" style="font-size:0.85rem;"></span>
                <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <div id="photoCarousel" class="carousel slide" data-bs-ride="false">
                    <div class="carousel-inner" id="photoCarouselInner"></div>
                    <button class="carousel-control-prev" type="button" data-bs-target="#photoCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon"></span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#photoCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon"></span>
                    </button>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0 justify-content-center">
                <div id="photoCarouselDots" class="d-flex gap-2"></div>
            </div>
        </div>
    </div>
</div>

@functions {
    string ImageProxyUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url)) return string.Empty;
        return $"/image-proxy?url={Uri.EscapeDataString(url)}";
    }

    string GetStatusBadge(string status) => status switch
    {
        "Pending"    => "bg-warning text-dark",
        "Paid"       => "bg-info text-white",
        "Processing" => "bg-primary",
        "Delivered"  => "bg-success",
        "Cancelled"  => "bg-danger",
        _            => "bg-secondary"
    };

    string GetTimelineDot(string status) => status switch
    {
        "Pending"    => "#f59e0b",
        "Paid"       => "#06b6d4",
        "Processing" => "#3b82f6",
        "Delivered"  => "#22c55e",
        "Cancelled"  => "#ef4444",
        _            => "#9ca3af"
    };
}

@section Scripts {
<script>
// ── Photo Carousel ─────────────────────────────────────────────────────────
function openPhotoCarousel(img) {
    const photos = img.dataset.photos.split(',').filter(Boolean);
    const startIndex = parseInt(img.dataset.index) || 0;

    const inner = document.getElementById('photoCarouselInner');
    const dots  = document.getElementById('photoCarouselDots');
    inner.innerHTML = '';
    dots.innerHTML  = '';

    photos.forEach((url, i) => {
        inner.innerHTML += `
            <div class="carousel-item ${i === startIndex ? 'active' : ''}">
                <img src="${url}" class="d-block mx-auto"
                     style="max-height:70vh;max-width:100%;object-fit:contain;"
                     alt="Review photo ${i+1}" />
            </div>`;
        dots.innerHTML += `
            <div class="rounded-circle ${i === startIndex ? 'bg-white' : 'bg-secondary'}"
                 style="width:8px;height:8px;cursor:pointer;"
                 onclick="bootstrap.Carousel.getInstance(document.getElementById('photoCarousel')).to(${i})">
            </div>`;
    });

    // Update counter and dots on slide
    const carousel = document.getElementById('photoCarousel');
    const counter  = document.getElementById('photoCarouselCounter');
    counter.textContent = `${startIndex + 1} / ${photos.length}`;

    carousel.addEventListener('slid.bs.carousel', e => {
        const idx = e.to;
        counter.textContent = `${idx + 1} / ${photos.length}`;
        dots.querySelectorAll('div').forEach((d, i) => {
            d.className = `rounded-circle ${i === idx ? 'bg-white' : 'bg-secondary'}`;
            d.style.cssText = 'width:8px;height:8px;cursor:pointer;';
        });
    }, { once: false });

    // Show/hide nav arrows
    const prevBtn = carousel.querySelector('.carousel-control-prev');
    const nextBtn = carousel.querySelector('.carousel-control-next');
    prevBtn.style.display = photos.length > 1 ? '' : 'none';
    nextBtn.style.display = photos.length > 1 ? '' : 'none';

    const modal = new bootstrap.Modal(document.getElementById('photoCarouselModal'));
    modal.show();

    // Jump to start index after modal shown
    setTimeout(() => {
        bootstrap.Carousel.getInstance(carousel)?.to(startIndex);
    }, 150);
}

// ── Quick Order Search ─────────────────────────────────────────────────────
(function () {
    const input    = document.getElementById('quickSearch');
    const dropdown = document.getElementById('quickSearchDropdown');
    const spinner  = document.getElementById('quickSearchSpinner');
    if (!input) return;

    let timer;

    const badge = s => {
        const m = { Pending:'bg-warning text-dark', Paid:'bg-info text-white',
                    Processing:'bg-primary text-white', Delivered:'bg-success text-white',
                    Cancelled:'bg-danger text-white' };
        return `<span class="badge ${m[s]??'bg-secondary'}" style="font-size:0.7rem;">${s}</span>`;
    };

    input.addEventListener('input', () => {
        clearTimeout(timer);
        const q = input.value.trim();
        if (q.length < 2) { dropdown.style.display = 'none'; return; }

        timer = setTimeout(async () => {
            spinner.style.display = '';
            try {
                const res  = await fetch(`/Orders/QuickSearch?q=${encodeURIComponent(q)}`);
                const data = await res.json();
                spinner.style.display = 'none';

                if (!data.length) {
                    dropdown.innerHTML =
                        `<div class="px-3 py-2 text-muted" style="font-size:0.85rem;">
                            No orders found for <strong>${q}</strong>
                         </div>`;
                    dropdown.style.display = '';
                    return;
                }

                if (data.length === 1) {
                    window.location.href = `/Orders/Detail/${data[0].id}`;
                    return;
                }

                dropdown.innerHTML =
                    data.map(o =>
                        `<a href="/Orders/Detail/${o.id}"
                            class="d-flex align-items-center justify-content-between px-3 py-2 border-bottom text-decoration-none"
                            style="font-size:0.85rem;color:inherit;"
                            onmouseover="this.style.background='#f9fafb'"
                            onmouseout="this.style.background=''">
                            <div>
                                <span class="fw-semibold">${o.orderNumber}</span>
                                <span class="text-muted ms-2" style="font-size:0.78rem;">${o.customerName??''}</span>
                            </div>
                            <div class="d-flex align-items-center gap-2 flex-shrink-0">
                                ${badge(o.status)}
                                <span class="text-muted" style="font-size:0.78rem;">
                                    ₱${Number(o.total).toLocaleString('en-PH',{minimumFractionDigits:2})}
                                </span>
                                <span class="text-muted" style="font-size:0.75rem;">${o.date}</span>
                            </div>
                         </a>`
                    ).join('') +
                    `<div class="px-3 py-2">
                        <a href="/Orders/Index?search=${encodeURIComponent(q)}"
                           class="text-primary text-decoration-none" style="font-size:0.82rem;">
                            <i class="bi bi-list me-1"></i>See all results in Orders list
                        </a>
                     </div>`;
                dropdown.style.display = '';
            } catch {
                spinner.style.display = 'none';
            }
        }, 280);
    });

    document.addEventListener('click', e => {
        if (!input.contains(e.target) && !dropdown.contains(e.target))
            dropdown.style.display = 'none';
    });

    input.addEventListener('keydown', e => {
        if (e.key === 'Escape') { dropdown.style.display = 'none'; input.blur(); }
    });
})();
</script>
}
