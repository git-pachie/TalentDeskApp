@model OrderModel
@{
    ViewData["Title"] = $"Order {Model.OrderNumber}";
}

<div class="page-header">
    <div>
        <h2><i class="bi bi-receipt me-2 text-primary"></i>@Model.OrderNumber</h2>
        <p class="text-muted mb-0" style="font-size: 0.85rem;">Placed on @Model.CreatedAt.ToString("MMMM dd, yyyy 'at' hh:mm tt")</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back to Orders
    </a>
</div>

<div class="row g-3">
    @* ===== LEFT: Items ===== *@
    <div class="col-lg-8">
        <div class="card data-card mb-3">
            <div class="card-header">
                <h5><i class="bi bi-bag me-2"></i>Order Items</h5>
            </div>
            <table class="table data-table">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th class="text-end">Unit Price</th>
                        <th class="text-center">Qty</th>
                        <th class="text-end">Total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="fw-semibold">@item.ProductName</td>
                            <td class="text-end">₱@item.UnitPrice.ToString("N2")</td>
                            <td class="text-center">
                                <span class="badge bg-light text-dark border">@item.Quantity</span>
                            </td>
                            <td class="text-end fw-semibold">₱@item.TotalPrice.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
            </table>
            <div class="card-footer bg-white px-3 py-3">
                <div class="d-flex justify-content-end">
                    <div style="min-width: 250px;">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-muted">Subtotal</span>
                            <span>₱@Model.SubTotal.ToString("N2")</span>
                        </div>
                        @if (Model.DiscountAmount > 0)
                        {
                            <div class="d-flex justify-content-between mb-1 text-success">
                                <span>Discount</span>
                                <span>-₱@Model.DiscountAmount.ToString("N2")</span>
                            </div>
                        }
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Delivery Fee</span>
                            <span>₱@Model.DeliveryFee.ToString("N2")</span>
                        </div>
                        <hr class="my-2" />
                        <div class="d-flex justify-content-between fw-bold fs-5">
                            <span>Total</span>
                            <span>₱@Model.TotalAmount.ToString("N2")</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Notes))
        {
            <div class="card form-card mb-3">
                <div class="card-body">
                    <h6 class="fw-bold mb-2"><i class="bi bi-chat-left-text me-2"></i>Order Notes</h6>
                    <p class="text-muted mb-0">@Model.Notes</p>
                </div>
            </div>
        }
    </div>

    @* ===== RIGHT: Sidebar ===== *@
    <div class="col-lg-4">
        @* Status Card *@
        <div class="card form-card mb-3">
            <div class="card-body">
                <h6 class="fw-bold mb-3"><i class="bi bi-flag me-2"></i>Order Status</h6>
                <div class="text-center mb-3">
                    <span class="badge badge-status @GetStatusBadge(Model.Status) fs-6 px-3 py-2">@Model.Status</span>
                </div>
                <form asp-action="UpdateStatus" asp-route-id="@Model.Id" method="post">
                    <div class="mb-2">
                        <select name="status" class="form-select">
                            <option value="Pending" selected="@(Model.Status == "Pending")">Pending</option>
                            <option value="Paid" selected="@(Model.Status == "Paid")">Paid</option>
                            <option value="Processing" selected="@(Model.Status == "Processing")">Processing</option>
                            <option value="Delivered" selected="@(Model.Status == "Delivered")">Delivered</option>
                            <option value="Cancelled" selected="@(Model.Status == "Cancelled")">Cancelled</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-arrow-repeat me-1"></i> Update Status
                    </button>
                </form>
            </div>
        </div>

        @* Payment Card *@
        @if (Model.Payment is not null)
        {
            <div class="card form-card mb-3">
                <div class="card-body">
                    <h6 class="fw-bold mb-3"><i class="bi bi-credit-card me-2"></i>Payment</h6>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Method</span>
                        <span class="fw-medium">@Model.Payment.Method</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Status</span>
                        <span class="badge badge-status @(Model.Payment.Status == "Paid" ? "bg-success" : "bg-warning text-dark")">@Model.Payment.Status</span>
                    </div>
                    @if (Model.Payment.PaidAt.HasValue)
                    {
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Paid at</span>
                            <span>@Model.Payment.PaidAt.Value.ToString("MMM dd, HH:mm")</span>
                        </div>
                    }
                </div>
            </div>
        }

        @* Address Card *@
        @if (Model.Address is not null)
        {
            <div class="card form-card mb-3">
                <div class="card-body">
                    <h6 class="fw-bold mb-3"><i class="bi bi-geo-alt me-2"></i>Delivery Address</h6>
                    <div class="d-flex align-items-start gap-2">
                        <span class="badge bg-primary-subtle text-primary">@Model.Address.Label</span>
                        <div>
                            <div>@Model.Address.Street</div>
                            <div class="text-muted">@Model.Address.City, @Model.Address.Province @Model.Address.ZipCode</div>
                        </div>
                    </div>
                </div>
            </div>
        }

        @* Timeline Card *@
        @if (Model.StatusHistory.Count > 0)
        {
            <div class="card form-card mb-3">
                <div class="card-body">
                    <h6 class="fw-bold mb-3"><i class="bi bi-clock-history me-2"></i>Status Timeline</h6>
                    <div class="position-relative" style="padding-left: 20px;">
                        @foreach (var entry in Model.StatusHistory)
                        {
                            <div class="d-flex mb-3 position-relative">
                                <div class="position-absolute" style="left: -20px; top: 4px; width: 10px; height: 10px; border-radius: 50%; background: @GetTimelineDot(entry.Status); border: 2px solid #fff; box-shadow: 0 0 0 2px @GetTimelineDot(entry.Status);"></div>
                                @if (entry != Model.StatusHistory.Last())
                                {
                                    <div class="position-absolute" style="left: -16px; top: 16px; width: 2px; height: calc(100% + 4px); background: #e5e7eb;"></div>
                                }
                                <div>
                                    <div class="fw-semibold" style="font-size: 0.85rem;">@entry.Status</div>
                                    <div class="text-muted" style="font-size: 0.75rem;">@entry.CreatedAt.ToString("MMM dd, HH:mm") · @entry.CreatedBy</div>
                                    @if (!string.IsNullOrEmpty(entry.Notes))
                                    {
                                        <div class="text-muted" style="font-size: 0.8rem;">@entry.Notes</div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@functions {
    string GetStatusBadge(string status) => status switch
    {
        "Pending" => "bg-warning text-dark",
        "Paid" => "bg-info text-white",
        "Processing" => "bg-primary",
        "Delivered" => "bg-success",
        "Cancelled" => "bg-danger",
        _ => "bg-secondary"
    };

    string GetTimelineDot(string status) => status switch
    {
        "Pending" => "#f59e0b",
        "Paid" => "#06b6d4",
        "Processing" => "#3b82f6",
        "Delivered" => "#22c55e",
        "Cancelled" => "#ef4444",
        _ => "#9ca3af"
    };
}
