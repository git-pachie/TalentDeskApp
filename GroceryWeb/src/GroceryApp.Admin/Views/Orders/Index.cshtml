@model List<OrderModel>
@{
    ViewData["Title"] = "Orders";
}

<div class="page-header">
    <div>
        <h2><i class="bi bi-receipt me-2 text-primary"></i>Orders</h2>
        <p class="text-muted mb-0" style="font-size: 0.85rem;">View and manage customer orders</p>
    </div>
</div>

<div class="card data-card">
    <table class="table data-table">
        <thead>
            <tr>
                <th>Order</th>
                <th>Discount</th>
                <th>Delivery</th>
                <th>Total</th>
                <th>Status</th>
                <th>Date</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Count > 0)
            {
                @foreach (var order in Model)
                {
                    <tr>
                        <td>
                            <a asp-action="Detail" asp-route-id="@order.Id" class="fw-semibold text-decoration-none">
                                @order.OrderNumber
                            </a>
                            <div class="text-muted" style="font-size: 0.8rem;">₱@order.SubTotal.ToString("N2")</div>
                        </td>
                        <td>
                            @if (order.DiscountAmount > 0)
                            {
                                <span class="text-success fw-medium">-₱@order.DiscountAmount.ToString("N2")</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>₱@order.DeliveryFee.ToString("N2")</td>
                        <td class="fw-bold">₱@order.TotalAmount.ToString("N2")</td>
                        <td><span class="badge badge-status @GetStatusBadge(order.Status)">@order.Status</span></td>
                        <td class="text-muted">@order.CreatedAt.ToString("MMM dd, yyyy")</td>
                        <td class="text-end">
                            <a asp-action="Detail" asp-route-id="@order.Id" class="btn btn-xs btn-outline-primary me-1" title="View Details">
                                <i class="bi bi-eye"></i>
                            </a>
                            <form asp-action="UpdateStatus" asp-route-id="@order.Id" method="post" class="d-inline-flex align-items-center gap-1">
                                <select name="status" class="form-select form-select-sm" style="width: auto; font-size: 0.8rem; border-radius: 6px;">
                                    <option value="Pending" selected="@(order.Status == "Pending")">Pending</option>
                                    <option value="Paid" selected="@(order.Status == "Paid")">Paid</option>
                                    <option value="Processing" selected="@(order.Status == "Processing")">Processing</option>
                                    <option value="Delivered" selected="@(order.Status == "Delivered")">Delivered</option>
                                    <option value="Cancelled" selected="@(order.Status == "Cancelled")">Cancelled</option>
                                </select>
                                <button type="submit" class="btn btn-sm btn-primary" title="Update Status">
                                    <i class="bi bi-check-lg"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7">
                        <div class="empty-state">
                            <i class="bi bi-receipt"></i>
                            <p>No orders found.</p>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@functions {
    string GetStatusBadge(string status) => status switch
    {
        "Pending" => "bg-warning text-dark",
        "Paid" => "bg-info text-white",
        "Processing" => "bg-primary",
        "Delivered" => "bg-success",
        "Cancelled" => "bg-danger",
        _ => "bg-secondary"
    };
}
