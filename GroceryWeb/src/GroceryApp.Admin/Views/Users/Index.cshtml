@model PagedResultModel<UserModel>
@{
    ViewData["Title"] = "Users";
}

<div class="page-header">
    <div>
        <h2><i class="bi bi-people-fill me-2 text-primary"></i>Users</h2>
        <p class="text-muted mb-0" style="font-size: 0.85rem;">Manage registered users</p>
    </div>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Add User</a>
</div>

<div class="card data-card">
    <div class="card-header d-flex align-items-center justify-content-between">
        <h5 class="mb-0">All Users</h5>
        <form method="get" class="d-flex gap-2" style="max-width: 350px;">
            <div class="input-group input-group-sm">
                <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
                <input type="text" name="search" class="form-control border-start-0 ps-0" placeholder="Search name or email..."
                       value="@ViewBag.Search" style="font-size: 0.85rem;" />
            </div>
            <button type="submit" class="btn btn-sm btn-primary">Search</button>
            @if (!string.IsNullOrEmpty(ViewBag.Search as string))
            {
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Clear</a>
            }
        </form>
    </div>
    <table class="table data-table">
        <thead>
            <tr>
                <th>User</th>
                <th>Email</th>
                <th>Roles</th>
                <th>Orders</th>
                <th>Status</th>
                <th>Joined</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model?.Items != null && Model.Items.Count > 0)
            {
                @foreach (var user in Model.Items)
                {
                    var initials = $"{(user.FirstName.Length > 0 ? user.FirstName[0] : '?')}{(user.LastName.Length > 0 ? user.LastName[0] : '?')}";
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold"
                                     style="width: 36px; height: 36px; font-size: 0.75rem; background: linear-gradient(135deg, #6366f1, #8b5cf6); flex-shrink: 0;">
                                    @initials
                                </div>
                                <a asp-action="Detail" asp-route-id="@user.Id" class="fw-semibold text-decoration-none">
                                    @user.FirstName @user.LastName
                                </a>
                            </div>
                        </td>
                        <td class="text-muted">@user.Email</td>
                        <td>
                            @foreach (var role in user.Roles)
                            {
                                <span class="badge @(role == "Admin" ? "bg-danger-subtle text-danger" : "bg-primary-subtle text-primary")" style="font-size: 0.7rem;">@role</span>
                            }
                        </td>
                        <td>
                            <span class="badge bg-light text-dark border">@user.OrderCount</span>
                        </td>
                        <td>
                            @if (user.IsActive)
                            {
                                <span class="badge badge-status bg-success-subtle text-success">Active</span>
                            }
                            else
                            {
                                <span class="badge badge-status bg-danger-subtle text-danger">Locked</span>
                            }
                        </td>
                        <td class="text-muted">@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                        <td class="text-end">
                            <form asp-action="ToggleActive" asp-route-id="@user.Id" method="post" class="d-inline">
                                <button type="submit" class="btn btn-sm @(user.IsActive ? "btn-outline-warning" : "btn-outline-success")" title="@(user.IsActive ? "Lock" : "Unlock")">
                                    <i class="bi @(user.IsActive ? "bi-lock" : "bi-unlock")"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7">
                        <div class="empty-state">
                            <i class="bi bi-people"></i>
                            <p>No users found.</p>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (Model?.TotalPages > 1)
{
    <nav class="mt-3 d-flex justify-content-center">
        <ul class="pagination pagination-sm">
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-search="@ViewBag.Search"
                       style="border-radius: 6px; margin: 0 2px;">@i</a>
                </li>
            }
        </ul>
    </nav>
}
