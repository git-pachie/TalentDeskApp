<!-- Assign Voucher Modal -->
@if (allVouchers.Any())
{
    <div class="modal fade" id="assignVoucherModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-action="AssignVoucher" asp-route-id="@Model.Id" method="post">
                    <div class="modal-header">
                        <h5 class="modal-title"><i class="bi bi-ticket me-2"></i>Assign Voucher</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <label class="form-label fw-semibold">Select Voucher <span class="text-danger">*</span></label>
                        <select name="voucherId" class="form-select" required>
                            @foreach (var v in allVouchers)
                            {
                                var discountLabel = v.Type == "Percentage" ? $"{v.Value}% off" : $"₱{v.Value:N2} off";
                                <option value="@v.Id">@v.Code — @discountLabel (expires @v.ExpiryDate.ToString("MMM dd, yyyy"))</option>
                            }
                        </select>
                        <div class="form-text mt-2">Only active, non-expired vouchers are shown.</div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check me-1"></i>Assign</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
<script>
function populateEditAddress(btn) {
    document.getElementById('ea-label').value        = btn.dataset.label        ?? '';
    document.getElementById('ea-contact').value      = btn.dataset.contact      ?? '';
    document.getElementById('ea-street').value       = btn.dataset.street       ?? '';
    document.getElementById('ea-city').value         = btn.dataset.city         ?? '';
    document.getElementById('ea-province').value     = btn.dataset.province     ?? '';
    document.getElementById('ea-zip').value          = btn.dataset.zip          ?? '';
    document.getElementById('ea-instructions').value = btn.dataset.instructions ?? '';
    document.getElementById('ea-lat').value          = btn.dataset.lat          ?? '';
    document.getElementById('ea-lng').value          = btn.dataset.lng          ?? '';
    document.getElementById('ea-default').checked    = btn.dataset.default === 'true';
    document.getElementById('editAddressForm').action =
        `/Users/EditAddress?id=@Model.Id&addressId=${btn.dataset.id}`;
}

function populateEditPayment(btn) {
    document.getElementById('ep-type').value    = btn.dataset.type    ?? 'CreditCard';
    document.getElementById('ep-name').value    = btn.dataset.name    ?? '';
    document.getElementById('ep-detail').value  = btn.dataset.detail  ?? '';
    document.getElementById('ep-default').checked = btn.dataset.default === 'true';
    document.getElementById('editPaymentForm').action =
        `/Users/EditPaymentMethod?id=@Model.Id&pmId=${btn.dataset.id}`;
}
</script>
}
