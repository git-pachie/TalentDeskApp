@model CreateUserModel
@{
    ViewData["Title"] = "Create User";
    var availableRoles = ViewBag.AvailableRoles as List<string> ?? [];
}

<div class="page-header">
    <div>
        <h2><i class="bi bi-person-plus-fill me-2 text-primary"></i>Create User</h2>
        <p class="text-muted mb-0" style="font-size:0.85rem;">Add a new account and assign roles</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

<form asp-action="Create" method="post">
    <div class="card form-card">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">First Name</label>
                    <input name="FirstName" class="form-control" value="@Model.FirstName" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Last Name</label>
                    <input name="LastName" class="form-control" value="@Model.LastName" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Email</label>
                    <input name="Email" type="email" class="form-control" value="@Model.Email" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Phone</label>
                    <input name="PhoneNumber" class="form-control" value="@Model.PhoneNumber" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Password</label>
                    <input name="Password" type="password" class="form-control" required />
                </div>
                <div class="col-12">
                    <label class="form-label">Roles</label>
                    <div class="d-flex flex-wrap gap-3">
                        @foreach (var role in availableRoles)
                        {
                            <label class="form-check-label d-flex align-items-center gap-2">
                                <input class="form-check-input" type="checkbox" name="Roles" value="@role" @(Model.Roles.Contains(role) ? "checked" : null) />
                                <span>@role</span>
                            </label>
                        }
                    </div>
                </div>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Create User</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </div>
    </div>
</form>
