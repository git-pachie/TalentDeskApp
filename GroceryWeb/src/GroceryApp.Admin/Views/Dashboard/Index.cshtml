@{
    ViewData["Title"] = "Dashboard";
}

<h2>Dashboard</h2>
<p>Welcome, @ViewBag.UserName!</p>

<div class="row mt-4">
    <div class="col-md-3">
        <div class="card text-bg-primary mb-3">
            <div class="card-body">
                <h5 class="card-title">Products</h5>
                <p class="card-text display-6">—</p>
                <a asp-controller="Products" asp-action="Index" class="text-white">Manage →</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-bg-success mb-3">
            <div class="card-body">
                <h5 class="card-title">Orders</h5>
                <p class="card-text display-6">—</p>
                <a asp-controller="Orders" asp-action="Index" class="text-white">View →</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-bg-warning mb-3">
            <div class="card-body">
                <h5 class="card-title">Categories</h5>
                <p class="card-text display-6">—</p>
                <a asp-controller="Categories" asp-action="Index" class="text-white">Manage →</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-bg-info mb-3">
            <div class="card-body">
                <h5 class="card-title">Vouchers</h5>
                <p class="card-text display-6">—</p>
                <a asp-controller="Vouchers" asp-action="Index" class="text-white">Manage →</a>
            </div>
        </div>
    </div>
</div>
