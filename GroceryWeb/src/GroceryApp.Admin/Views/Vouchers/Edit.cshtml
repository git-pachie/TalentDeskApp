@model VoucherModel
@{
    ViewData["Title"] = $"Edit Voucher — {Model.Code}";
}

<div class="page-header">
    <div>
        <h2><i class="bi bi-pencil-fill me-2 text-primary"></i>Edit Voucher</h2>
        <p class="text-muted mb-0" style="font-size: 0.85rem;"><code>@Model.Code</code></p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back
    </a>
</div>

<div class="row">
    <div class="col-lg-8">
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
            <div class="card form-card mb-3">
                <div class="card-body">
                    <h6 class="fw-bold mb-3">Voucher Details</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Voucher Code</label>
                            <input class="form-control" value="@Model.Code" disabled />
                            <div class="form-text">Code cannot be changed after creation.</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Type</label>
                            <input class="form-control" value="@Model.Type" disabled />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Description</label>
                            <textarea name="Description" class="form-control" rows="2">@Model.Description</textarea>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card form-card mb-3">
                <div class="card-body">
                    <h6 class="fw-bold mb-3">Value & Limits</h6>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Discount Value</label>
                            <input name="Value" class="form-control" type="number" step="0.01" min="0"
                                   value="@Model.Value" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Max Discount (₱)</label>
                            <input name="MaxDiscount" class="form-control" type="number" step="0.01" min="0"
                                   value="@Model.MaxDiscount" placeholder="For % type" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Min Spend (₱)</label>
                            <input name="MinimumSpend" class="form-control" type="number" step="0.01" min="0"
                                   value="@Model.MinimumSpend" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Usage Limit</label>
                            <input name="UsageLimit" class="form-control" type="number" min="1"
                                   value="@Model.UsageLimit" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Expiry Date</label>
                            <input name="ExpiryDate" class="form-control" type="date"
                                   value="@Model.ExpiryDate.ToString("yyyy-MM-dd")" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Status</label>
                            <select name="IsActive" class="form-select">
                                <option value="true" selected="@(Model.IsActive)">Active</option>
                                <option value="false" selected="@(!Model.IsActive)">Disabled</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-check-lg me-1"></i> Save Changes
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>

    <div class="col-lg-4">
        <div class="card form-card">
            <div class="card-body">
                <h6 class="fw-bold mb-3"><i class="bi bi-bar-chart me-2"></i>Usage Stats</h6>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Used</span>
                    <span class="fw-bold">@Model.UsedCount / @Model.UsageLimit</span>
                </div>
                @{
                    var pct = Model.UsageLimit > 0 ? (int)((double)Model.UsedCount / Model.UsageLimit * 100) : 0;
                }
                <div class="progress mb-3" style="height: 8px;">
                    <div class="progress-bar @(pct > 80 ? "bg-danger" : "bg-primary")" style="width: @pct%"></div>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Expires</span>
                    <span class="fw-semibold @(Model.ExpiryDate < DateTime.UtcNow ? "text-danger" : "")">
                        @Model.ExpiryDate.ToString("MMM dd, yyyy")
                    </span>
                </div>
                <div class="d-flex justify-content-between">
                    <span class="text-muted">Status</span>
                    @if (!Model.IsActive)
                    {
                        <span class="badge bg-secondary">Disabled</span>
                    }
                    else if (Model.ExpiryDate < DateTime.UtcNow)
                    {
                        <span class="badge bg-danger-subtle text-danger">Expired</span>
                    }
                    else
                    {
                        <span class="badge bg-success-subtle text-success">Active</span>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
