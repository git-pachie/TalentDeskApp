@model LoginViewModel
@{
    ViewData["Title"] = "Sign In";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign In - GroceryApp Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="~/vendors/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/vendors/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    <style>
        * { font-family: 'Inter', system-ui, sans-serif; }

        body {
            min-height: 100vh;
            margin: 0;
            display: flex;
            background: #f8fafc;
        }

        .login-left {
            flex: 1;
            background: linear-gradient(135deg, #059669 0%, #065f46 50%, #064e3b 100%);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 3rem;
            position: relative;
            overflow: hidden;
        }

        .login-left::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle at 30% 70%, rgba(255,255,255,0.06) 0%, transparent 50%),
                        radial-gradient(circle at 70% 30%, rgba(255,255,255,0.04) 0%, transparent 50%);
            animation: float 20s ease-in-out infinite;
        }

        @@keyframes float {
            0%, 100% { transform: translate(0, 0) rotate(0deg); }
            50% { transform: translate(-20px, -20px) rotate(2deg); }
        }

        .login-left-content {
            position: relative;
            z-index: 1;
            text-align: center;
            max-width: 400px;
        }

        .login-left-content .brand-icon {
            width: 72px;
            height: 72px;
            background: rgba(255,255,255,0.15);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.2);
        }

        .login-left-content .brand-icon i {
            font-size: 2rem;
            color: #fff;
        }

        .login-left-content h1 {
            color: #fff;
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 0.75rem;
        }

        .login-left-content p {
            color: rgba(255,255,255,0.75);
            font-size: 1rem;
            line-height: 1.6;
            margin-bottom: 2rem;
        }

        .feature-list {
            list-style: none;
            padding: 0;
            margin: 0;
            text-align: left;
        }

        .feature-list li {
            color: rgba(255,255,255,0.85);
            font-size: 0.9rem;
            padding: 0.5rem 0;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .feature-list li i {
            color: #6ee7b7;
            font-size: 1.1rem;
            flex-shrink: 0;
        }

        .login-right {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }

        .login-form-container {
            width: 100%;
            max-width: 420px;
        }

        .login-header {
            margin-bottom: 2rem;
        }

        .login-header h2 {
            font-size: 1.5rem;
            font-weight: 700;
            color: #18181b;
            margin-bottom: 0.5rem;
        }

        .login-header p {
            color: #71717a;
            font-size: 0.9rem;
            margin: 0;
        }

        .form-label {
            font-size: 0.8rem;
            font-weight: 600;
            color: #3f3f46;
            text-transform: uppercase;
            letter-spacing: 0.03em;
            margin-bottom: 0.4rem;
        }

        .form-control {
            padding: 0.7rem 1rem;
            border-radius: 10px;
            border: 1.5px solid #e4e4e7;
            font-size: 0.9rem;
            transition: all 0.2s ease;
            background: #fff;
        }

        .form-control:focus {
            border-color: #059669;
            box-shadow: 0 0 0 3px rgba(5, 150, 105, 0.1);
        }

        .form-control::placeholder {
            color: #a1a1aa;
        }

        .input-icon-wrapper {
            position: relative;
        }

        .input-icon-wrapper i {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: #a1a1aa;
            font-size: 1rem;
            pointer-events: none;
        }

        .input-icon-wrapper .form-control {
            padding-left: 2.75rem;
        }

        .btn-login {
            width: 100%;
            padding: 0.75rem;
            border-radius: 10px;
            font-size: 0.9rem;
            font-weight: 600;
            background: #059669;
            border: none;
            color: #fff;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }

        .btn-login:hover {
            background: #047857;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(5, 150, 105, 0.3);
        }

        .btn-login:active {
            transform: translateY(0);
        }

        .alert-error {
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #991b1b;
            border-radius: 10px;
            padding: 0.75rem 1rem;
            font-size: 0.85rem;
            margin-bottom: 1.25rem;
        }

        .login-footer {
            margin-top: 2rem;
            text-align: center;
            color: #a1a1aa;
            font-size: 0.8rem;
        }

        .password-toggle {
            position: absolute;
            right: 1rem;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: #a1a1aa;
            cursor: pointer;
            padding: 0;
            font-size: 1rem;
        }

        .password-toggle:hover {
            color: #3f3f46;
        }

        @@media (max-width: 991.98px) {
            .login-left { display: none; }
            .login-right { padding: 1.5rem; }
        }
    </style>
</head>
<body>
    <!-- Left Panel - Branding -->
    <div class="login-left">
        <div class="login-left-content">
            <div class="brand-icon">
                <i class="bi bi-cart3"></i>
            </div>
            <h1>GroceryApp Admin</h1>
            <p>Manage your grocery store with a powerful, intuitive dashboard built for efficiency.</p>
            <ul class="feature-list">
                <li><i class="bi bi-check-circle-fill"></i> Real-time order monitoring</li>
                <li><i class="bi bi-check-circle-fill"></i> Product & inventory management</li>
                <li><i class="bi bi-check-circle-fill"></i> Customer insights & analytics</li>
                <li><i class="bi bi-check-circle-fill"></i> Voucher & promotion tools</li>
                <li><i class="bi bi-check-circle-fill"></i> Multi-payment provider support</li>
            </ul>
        </div>
    </div>

    <!-- Right Panel - Login Form -->
    <div class="login-right">
        <div class="login-form-container">
            <div class="login-header">
                <h2>Welcome back</h2>
                <p>Enter your credentials to access the admin panel</p>
            </div>

            @if (ViewData.ModelState.ErrorCount > 0)
            {
                <div class="alert-error">
                    <i class="bi bi-exclamation-circle me-1"></i>
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <span>@error.ErrorMessage</span>
                    }
                </div>
            }

            <form asp-action="Login" method="post" novalidate>
                <div class="mb-3">
                    <label class="form-label">Email Address</label>
                    <div class="input-icon-wrapper">
                        <i class="bi bi-envelope"></i>
                        <input asp-for="Email" class="form-control" type="email"
                               placeholder="admin@groceryapp.com" required autocomplete="email" />
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label">Password</label>
                    <div class="input-icon-wrapper">
                        <i class="bi bi-lock"></i>
                        <input asp-for="Password" class="form-control" type="password" id="passwordInput"
                               placeholder="Enter your password" required autocomplete="current-password" />
                        <button type="button" class="password-toggle" onclick="togglePassword()">
                            <i class="bi bi-eye" id="toggleIcon"></i>
                        </button>
                    </div>
                </div>

                <button type="submit" class="btn-login">
                    <i class="bi bi-arrow-right-circle"></i>
                    Sign In
                </button>
            </form>

            <div class="login-footer">
                <p>&copy; @DateTime.Now.Year GroceryApp. All rights reserved.</p>
            </div>
        </div>
    </div>

    <script>
        function togglePassword() {
            const input = document.getElementById('passwordInput');
            const icon = document.getElementById('toggleIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('bi-eye', 'bi-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('bi-eye-slash', 'bi-eye');
            }
        }
    </script>
</body>
</html>
