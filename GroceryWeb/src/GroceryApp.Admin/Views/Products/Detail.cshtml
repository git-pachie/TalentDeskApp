@model ProductModel
@{
    ViewData["Title"] = Model.Name;
    var primaryImage = Model.Images.FirstOrDefault(i => i.IsPrimary) ?? Model.Images.FirstOrDefault();
}

<div class="page-header">
    <div>
        <h2><i class="bi bi-box-seam-fill me-2 text-primary"></i>@Model.Name</h2>
        <p class="text-muted mb-0" style="font-size: 0.85rem;">Product details</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
            <i class="bi bi-pencil me-1"></i> Edit
        </a>
        <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteModal">
            <i class="bi bi-trash me-1"></i> Delete
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Back
        </a>
    </div>
</div>

<div class="row g-3">
    @* ===== LEFT: Images + Info ===== *@
    <div class="col-lg-8">
        @* Images Gallery *@
        @if (Model.Images.Count > 0)
        {
            <div class="card form-card mb-3">
                <div class="card-body">
                    <h6 class="fw-bold mb-3"><i class="bi bi-images me-2"></i>Product Images</h6>
                    <div class="row g-2">
                        @foreach (var image in Model.Images.OrderBy(i => i.SortOrder))
                        {
                            <div class="col-md-3 col-sm-4 col-6">
                                <div class="position-relative" style="border-radius: 10px; overflow: hidden; border: 2px solid @(image.IsPrimary ? "#4f46e5" : "#e5e7eb");">
                                    <img src="@(ViewBag.ProductImageUrl)/@(image.ImageUrl)" alt="Product image"
                                         onerror="this.onerror=null;this.src='/images/default-product.svg';"
                                         style="width: 100%; aspect-ratio: 1; object-fit: cover; display: block;" />
                                    @if (image.IsPrimary)
                                    {
                                        <span class="position-absolute top-0 start-0 badge bg-primary m-1" style="font-size: 0.65rem; border-radius: 4px;">
                                            <i class="bi bi-star-fill me-1"></i>Primary
                                        </span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="card form-card mb-3">
                <div class="card-body text-center py-4">
                    <img src="/images/default-product.svg" alt="No image" style="width: 120px; height: 120px; opacity: 0.7;" />
                    <p class="text-muted mt-2 mb-0">No product images uploaded</p>
                </div>
            </div>
        }

        @* Product Info *@
        <div class="card form-card mb-3">
            <div class="card-body">
                <h6 class="fw-bold mb-3"><i class="bi bi-info-circle me-2"></i>Product Information</h6>
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="p-3 rounded" style="background: #f9fafb;">
                            <div class="text-muted" style="font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">Product Name</div>
                            <div class="fw-semibold mt-1">@Model.Name</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3 rounded" style="background: #f9fafb;">
                            <div class="text-muted" style="font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">Unit</div>
                            <div class="fw-semibold mt-1">@(Model.Unit ?? "—")</div>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="p-3 rounded" style="background: #f9fafb;">
                            <div class="text-muted" style="font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">Description</div>
                            <div class="mt-1">@(Model.Description ?? "No description provided.")</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* Pricing *@
        <div class="card form-card mb-3">
            <div class="card-body">
                <h6 class="fw-bold mb-3"><i class="bi bi-tag me-2"></i>Pricing & Inventory</h6>
                <div class="row g-3">
                    <div class="col-md-3">
                        <div class="p-3 rounded text-center" style="background: #f9fafb;">
                            <div class="text-muted" style="font-size: 0.7rem; font-weight: 600; text-transform: uppercase;">Price</div>
                            <div class="fw-bold fs-5 mt-1">₱@Model.Price.ToString("N2")</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="p-3 rounded text-center" style="background: #f9fafb;">
                            <div class="text-muted" style="font-size: 0.7rem; font-weight: 600; text-transform: uppercase;">Discount Price</div>
                            <div class="fw-bold fs-5 mt-1 @(Model.DiscountPrice.HasValue && Model.DiscountPrice > 0 ? "text-success" : "")">
                                @(Model.DiscountPrice.HasValue && Model.DiscountPrice > 0 ? $"₱{Model.DiscountPrice:N2}" : "—")
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="p-3 rounded text-center" style="background: #f9fafb;">
                            <div class="text-muted" style="font-size: 0.7rem; font-weight: 600; text-transform: uppercase;">Stock</div>
                            <div class="fw-bold fs-5 mt-1 @(Model.StockQuantity <= 10 ? "text-danger" : "")">@Model.StockQuantity</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="p-3 rounded text-center" style="background: #f9fafb;">
                            <div class="text-muted" style="font-size: 0.7rem; font-weight: 600; text-transform: uppercase;">Status</div>
                            <div class="mt-1">
                                @if (Model.IsActive)
                                {
                                    <span class="badge bg-success-subtle text-success px-3 py-2">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary px-3 py-2">Inactive</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ===== RIGHT: Sidebar ===== *@
    <div class="col-lg-4">
        @* Categories *@
        <div class="card form-card mb-3">
            <div class="card-body">
                <h6 class="fw-bold mb-3"><i class="bi bi-tags me-2"></i>Categories</h6>
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge bg-primary px-3 py-2" style="font-size: 0.8rem;">@Model.CategoryName</span>
                    @foreach (var cat in Model.Categories)
                    {
                        <span class="badge bg-primary-subtle text-primary px-3 py-2" style="font-size: 0.8rem;">@cat.Name</span>
                    }
                </div>
            </div>
        </div>

        @* Reviews Summary *@
        <div class="card form-card mb-3">
            <div class="card-body">
                <h6 class="fw-bold mb-3"><i class="bi bi-star me-2"></i>Reviews</h6>
                @if (Model.ReviewCount > 0)
                {
                    <div class="text-center">
                        <div class="fw-bold" style="font-size: 2.5rem; line-height: 1;">@Model.AverageRating.ToString("N1")</div>
                        <div class="my-2">
                            @for (int i = 0; i < 5; i++)
                            {
                                <i class="bi @(i < (int)Math.Round(Model.AverageRating) ? "bi-star-fill text-warning" : "bi-star text-muted")" style="font-size: 1.1rem;"></i>
                            }
                        </div>
                        <div class="text-muted" style="font-size: 0.85rem;">Based on @Model.ReviewCount review@(Model.ReviewCount != 1 ? "s" : "")</div>
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-2">
                        <i class="bi bi-star" style="font-size: 2rem;"></i>
                        <p class="mb-0 mt-2">No reviews yet</p>
                    </div>
                }
            </div>
        </div>

        @* Meta *@
        <div class="card form-card mb-3">
            <div class="card-body">
                <h6 class="fw-bold mb-3"><i class="bi bi-clock-history me-2"></i>Details</h6>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Product ID</span>
                    <code style="font-size: 0.75rem;">@Model.Id.ToString()[..8]...</code>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Created</span>
                    <span>@Model.CreatedAt.ToString("MMM dd, yyyy")</span>
                </div>
                <div class="d-flex justify-content-between">
                    <span class="text-muted">Images</span>
                    <span>@Model.Images.Count</span>
                </div>
            </div>
        </div>
    </div>
</div>

@* ===== DELETE MODAL ===== *@
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border: none; border-radius: 16px; overflow: hidden;">
            <div class="modal-body text-center p-4">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3"
                     style="width: 64px; height: 64px; background: #fef2f2;">
                    <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 1.8rem;"></i>
                </div>
                <h5 class="fw-bold mb-2">Delete Product</h5>
                <p class="text-muted mb-0">Are you sure you want to delete <strong>@Model.Name</strong>?</p>
                <p class="text-muted" style="font-size: 0.85rem;">This will deactivate the product.</p>
            </div>
            <div class="modal-footer border-0 justify-content-center gap-2 pb-4">
                <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Cancel</button>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline">
                    <button type="submit" class="btn btn-danger px-4">
                        <i class="bi bi-trash me-1"></i> Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
