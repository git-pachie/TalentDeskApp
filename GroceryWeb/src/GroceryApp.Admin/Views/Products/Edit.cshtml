@model ProductModel
@{
    ViewData["Title"] = "Edit Product";
    var categories = ViewBag.Categories as List<CategoryModel> ?? new List<CategoryModel>();
    var selectedCategoryIds = Model.Categories.Select(c => c.Id).ToHashSet();
}

<div class="page-header">
    <div>
        <h2><i class="bi bi-pencil-square me-2 text-primary"></i>Edit Product</h2>
        <p class="text-muted mb-0" style="font-size: 0.85rem;">Update <strong>@Model.Name</strong></p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Detail" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
            <i class="bi bi-eye me-1"></i> View
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Back
        </a>
    </div>
</div>

<form asp-action="Edit" asp-route-id="@Model.Id" method="post" id="productForm">
    <div class="row g-3">
        <div class="col-lg-8">
            <div class="card form-card mb-3">
                <div class="card-body">
                    <h6 class="fw-bold mb-3"><i class="bi bi-info-circle me-2"></i>Basic Information</h6>
                    <div class="mb-3">
                        <label class="form-label">Product Name</label>
                        <input name="Name" class="form-control" value="@Model.Name" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea name="Description" class="form-control" rows="3">@Model.Description</textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Unit</label>
                        <input name="Unit" class="form-control" value="@Model.Unit" placeholder="e.g. kg, pcs, pack" />
                    </div>
                </div>
            </div>

            <div class="card form-card mb-3">
                <div class="card-body">
                    <h6 class="fw-bold mb-3"><i class="bi bi-tag me-2"></i>Pricing & Inventory</h6>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Price (₱)</label>
                            <input name="Price" class="form-control" type="number" step="0.01" min="0" value="@Model.Price" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Discount Price (₱)</label>
                            <input name="DiscountPrice" class="form-control" type="number" step="0.01" min="0" value="@Model.DiscountPrice" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Stock Quantity</label>
                            <input name="StockQuantity" class="form-control" type="number" min="0" value="@Model.StockQuantity" required />
                        </div>
                    </div>
                </div>
            </div>

            @* ===== IMAGE UPLOAD ===== *@
            <div class="card form-card mb-3">
                <div class="card-body">
                    <h6 class="fw-bold mb-3"><i class="bi bi-images me-2"></i>Product Images</h6>

                    <div id="dropZone" class="text-center p-4 mb-3 rounded-3"
                         style="border: 2px dashed #d1d5db; background: #f9fafb; cursor: pointer; transition: all 0.2s;">
                        <i class="bi bi-cloud-arrow-up" style="font-size: 2.5rem; color: #9ca3af;"></i>
                        <p class="mb-1 fw-medium" style="color: #6b7280;">Drop images here or click to browse</p>
                        <p class="mb-0 text-muted" style="font-size: 0.8rem;">JPG, PNG, GIF, WebP — max 10 MB each</p>
                        <input type="file" id="fileInput" multiple accept="image/*" class="d-none" />
                    </div>

                    <div id="uploadProgress" class="mb-3 d-none">
                        <div class="progress" style="height: 6px; border-radius: 3px;">
                            <div class="progress-bar bg-primary" id="progressBar" style="width: 0%; transition: width 0.3s;"></div>
                        </div>
                        <small class="text-muted" id="progressText">Uploading...</small>
                    </div>

                    <div id="imagePreviewContainer" class="row g-2"></div>
                    <div id="imageHiddenFields"></div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card form-card mb-3">
                <div class="card-body">
                    <h6 class="fw-bold mb-3"><i class="bi bi-toggle-on me-2"></i>Status</h6>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="IsActive" value="true" id="isActiveSwitch"
                               @(Model.IsActive ? "checked" : "") style="width: 3em; height: 1.5em;" />
                        <label class="form-check-label fw-medium" for="isActiveSwitch">Product is active</label>
                    </div>
                </div>
            </div>

            <div class="card form-card mb-3">
                <div class="card-body">
                    <h6 class="fw-bold mb-3"><i class="bi bi-tags me-2"></i>Primary Category</h6>
                    <select name="CategoryId" class="form-select" required>
                        <option value="">Select a category...</option>
                        @foreach (var cat in categories)
                        {
                            if (cat.Id == Model.CategoryId)
                            {
                                <option value="@cat.Id" selected>@cat.Name</option>
                            }
                            else
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        }
                    </select>
                </div>
            </div>

            <div class="card form-card mb-3">
                <div class="card-body">
                    <h6 class="fw-bold mb-3"><i class="bi bi-collection me-2"></i>Additional Categories</h6>
                    <p class="text-muted" style="font-size: 0.8rem;">Select additional categories this product belongs to.</p>
                    @for (int i = 0; i < categories.Count; i++)
                    {
                        var isChecked = selectedCategoryIds.Contains(categories[i].Id);
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" name="CategoryIds" value="@categories[i].Id"
                                   id="cat_@i" @(isChecked ? "checked" : "") />
                            <label class="form-check-label" for="cat_@i" style="font-size: 0.875rem;">@categories[i].Name</label>
                        </div>
                    }
                </div>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary py-2" id="submitBtn">
                    <i class="bi bi-check-lg me-1"></i> Save Changes
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </div>
    </div>
</form>

@{
    // Pass existing images as JSON for the script to pre-populate
    var existingImages = Model.Images.Select(img => new { url = img.ImageUrl, isPrimary = img.IsPrimary }).ToList();
    var existingImagesJson = System.Text.Json.JsonSerializer.Serialize(existingImages,
        new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase });
    var productImageUrl = (string)(ViewBag.ProductImageUrl ?? "");
}

@await Html.PartialAsync("_ImageUploadScript")

<script>
    window.imageBaseUrl = '@Html.Raw(productImageUrl)';

    (function() {
        const existing = @Html.Raw(existingImagesJson);
        if (!Array.isArray(existing) || existing.length === 0) {
            return;
        }

        uploadedImages = existing.map(img => ({
            url: img.url,
            isPrimary: !!img.isPrimary
        }));

        if (!uploadedImages.some(img => img.isPrimary)) {
            uploadedImages[0].isPrimary = true;
        }

        renderImages();
    })();
</script>
