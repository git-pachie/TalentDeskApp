@model PagedResultModel<ProductModel>
@{
    ViewData["Title"] = "Products";
    var categories = (List<CategoryModel>?)ViewBag.Categories ?? [];
    var currentSearch = (string?)ViewBag.CurrentSearch ?? "";
    var currentCategoryId = (Guid?)ViewBag.CurrentCategoryId;
}

<div class="page-header">
    <div>
        <h2><i class="bi bi-box-seam-fill me-2 text-primary"></i>Products</h2>
        <p class="text-muted mb-0" style="font-size: 0.85rem;">Manage your product catalog</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Add Product
    </a>
</div>

<!-- Search & Filter Bar -->
<div class="card mb-3" style="border-radius: 10px;">
    <div class="card-body py-3">
        <form method="get" asp-action="Index" class="row g-2 align-items-end">
            <div class="col-md-5">
                <label class="form-label fw-semibold" style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.03em;">Search</label>
                <div class="input-group">
                    <span class="input-group-text bg-light"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" name="search" class="form-control" placeholder="Search by product name..."
                           value="@currentSearch" />
                </div>
            </div>
            <div class="col-md-4">
                <label class="form-label fw-semibold" style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.03em;">Category</label>
                <select name="categoryId" class="form-select">
                    <option value="">All Categories</option>
                    @foreach (var cat in categories)
                    {
                        <option value="@cat.Id" selected="@(currentCategoryId == cat.Id ? "selected" : null)">@cat.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-fill">
                    <i class="bi bi-funnel me-1"></i> Filter
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary flex-fill">
                    <i class="bi bi-x-lg me-1"></i> Clear
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Results Info -->
@if (Model != null)
{
    <div class="d-flex justify-content-between align-items-center mb-2">
        <small class="text-muted">
            Showing @((Model.Page - 1) * Model.PageSize + 1)–@(Math.Min(Model.Page * Model.PageSize, Model.TotalCount)) of @Model.TotalCount products
        </small>
        <small class="text-muted">Page @Model.Page of @Model.TotalPages</small>
    </div>
}

<div class="card data-card">
    <table class="table data-table">
        <thead>
            <tr>
                <th style="width: 140px;"></th>
                <th>Product</th>
                <th>Categories</th>
                <th>Price</th>
                <th>Stock</th>
                <th>Rating</th>
                <th>Status</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model?.Items != null && Model.Items.Count > 0)
            {
                @foreach (var product in Model.Items)
                {
                    var primaryImage = product.Images.FirstOrDefault(i => i.IsPrimary) ?? product.Images.FirstOrDefault();
                    <tr>
                        <td>
                            @if (primaryImage is not null)
                            {
                                <img src="@(ViewBag.ProductImageUrl)/@(primaryImage.ImageUrl)" alt="@product.Name"
                                     onerror="this.onerror=null;this.src='/images/default-product.svg';"
                                     style="width: 120px; height: 120px; object-fit: cover; border-radius: 8px; border: 1px solid #e5e7eb;" />
                            }
                            else
                            {
                                <img src="/images/default-product.svg" alt="No image"
                                     style="width: 120px; height: 120px; object-fit: cover; border-radius: 8px; border: 1px solid #e5e7eb;" />
                            }
                        </td>
                        <td>
                            <div class="fw-semibold">@product.Name</div>
                            @if (!string.IsNullOrEmpty(product.Unit))
                            {
                                <small class="text-muted">per @product.Unit</small>
                            }
                        </td>
                        <td>
                            <span class="badge bg-light text-dark border">@product.CategoryName</span>
                            @foreach (var cat in product.Categories)
                            {
                                <span class="badge bg-primary-subtle text-primary border-0" style="font-size: 0.7rem;">@cat.Name</span>
                            }
                        </td>
                        <td>
                            <span class="fw-semibold">₱@product.Price.ToString("N2")</span>
                            @if (product.DiscountPrice.HasValue && product.DiscountPrice.Value > 0)
                            {
                                <br /><small class="text-success fw-medium">₱@product.DiscountPrice.Value.ToString("N2")</small>
                            }
                        </td>
                        <td>
                            @if (product.StockQuantity <= 10)
                            {
                                <span class="badge bg-danger-subtle text-danger">@product.StockQuantity</span>
                            }
                            else
                            {
                                <span>@product.StockQuantity</span>
                            }
                        </td>
                        <td>
                            @if (product.ReviewCount > 0)
                            {
                                <span class="text-warning"><i class="bi bi-star-fill"></i></span>
                                <span style="font-size: 0.85rem;">@product.AverageRating.ToString("N1")</span>
                                <small class="text-muted">(@product.ReviewCount)</small>
                            }
                            else
                            {
                                <span class="text-muted" style="font-size: 0.8rem;">No reviews</span>
                            }
                        </td>
                        <td>
                            @if (product.IsActive)
                            {
                                <span class="badge badge-status bg-success-subtle text-success">Active</span>
                            }
                            else
                            {
                                <span class="badge badge-status bg-secondary-subtle text-secondary">Inactive</span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <a asp-action="Detail" asp-route-id="@product.Id" class="btn btn-outline-secondary" title="View Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@product.Id" class="btn btn-outline-primary" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <button type="button" class="btn btn-outline-danger" title="Delete"
                                        data-bs-toggle="modal" data-bs-target="#deleteModal"
                                        data-product-id="@product.Id" data-product-name="@product.Name">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8">
                        <div class="empty-state">
                            <i class="bi bi-box-seam"></i>
                            <p>No products found.</p>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (Model?.TotalPages > 1)
{
    <nav class="mt-3 d-flex justify-content-center">
        <ul class="pagination pagination-sm">
            <!-- Previous -->
            <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page - 1)"
                   asp-route-search="@currentSearch" asp-route-categoryId="@currentCategoryId"
                   style="border-radius: 6px; margin: 0 2px;">
                    <i class="bi bi-chevron-left"></i>
                </a>
            </li>

            @{
                var startPage = Math.Max(1, Model.Page - 3);
                var endPage = Math.Min(Model.TotalPages, Model.Page + 3);
            }

            @if (startPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-page="1"
                       asp-route-search="@currentSearch" asp-route-categoryId="@currentCategoryId"
                       style="border-radius: 6px; margin: 0 2px;">1</a>
                </li>
                @if (startPage > 2)
                {
                    <li class="page-item disabled"><span class="page-link" style="border-radius: 6px; margin: 0 2px;">…</span></li>
                }
            }

            @for (int i = startPage; i <= endPage; i++)
            {
                <li class="page-item @(i == Model.Page ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i"
                       asp-route-search="@currentSearch" asp-route-categoryId="@currentCategoryId"
                       style="border-radius: 6px; margin: 0 2px;">@i</a>
                </li>
            }

            @if (endPage < Model.TotalPages)
            {
                @if (endPage < Model.TotalPages - 1)
                {
                    <li class="page-item disabled"><span class="page-link" style="border-radius: 6px; margin: 0 2px;">…</span></li>
                }
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-page="@Model.TotalPages"
                       asp-route-search="@currentSearch" asp-route-categoryId="@currentCategoryId"
                       style="border-radius: 6px; margin: 0 2px;">@Model.TotalPages</a>
                </li>
            }

            <!-- Next -->
            <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page + 1)"
                   asp-route-search="@currentSearch" asp-route-categoryId="@currentCategoryId"
                   style="border-radius: 6px; margin: 0 2px;">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </li>
        </ul>
    </nav>
}

@* ===== DELETE CONFIRMATION MODAL ===== *@
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border: none; border-radius: 16px; overflow: hidden;">
            <div class="modal-body text-center p-4">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3"
                     style="width: 64px; height: 64px; background: #fef2f2;">
                    <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 1.8rem;"></i>
                </div>
                <h5 class="fw-bold mb-2">Delete Product</h5>
                <p class="text-muted mb-0">Are you sure you want to delete <strong id="deleteProductName"></strong>?</p>
                <p class="text-muted" style="font-size: 0.85rem;">This will deactivate the product. It can be reactivated later.</p>
            </div>
            <div class="modal-footer border-0 justify-content-center gap-2 pb-4">
                <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Cancel</button>
                <form id="deleteForm" method="post" class="d-inline">
                    <button type="submit" class="btn btn-danger px-4">
                        <i class="bi bi-trash me-1"></i> Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    var deleteModal = document.getElementById('deleteModal');
    deleteModal.addEventListener('show.bs.modal', function (event) {
        var button = event.relatedTarget;
        var productId = button.getAttribute('data-product-id');
        var productName = button.getAttribute('data-product-name');
        document.getElementById('deleteProductName').textContent = productName;
        document.getElementById('deleteForm').action = '/Products/Delete/' + productId;
    });
</script>
