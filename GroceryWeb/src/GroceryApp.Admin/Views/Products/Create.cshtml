@model CreateProductModel
@{
    ViewData["Title"] = "Add Product";
}

<h2>Add Product</h2>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            <div class="mb-3">
                <label asp-for="Name" class="form-label">Name</label>
                <input asp-for="Name" class="form-control" required />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label">Description</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Price" class="form-label">Price (₱)</label>
                <input asp-for="Price" class="form-control" type="number" step="0.01" min="0" required />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="DiscountPrice" class="form-label">Discount Price (₱)</label>
                <input asp-for="DiscountPrice" class="form-control" type="number" step="0.01" min="0" />
                <span asp-validation-for="DiscountPrice" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="StockQuantity" class="form-label">Stock Quantity</label>
                <input asp-for="StockQuantity" class="form-control" type="number" min="0" required />
                <span asp-validation-for="StockQuantity" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Unit" class="form-label">Unit</label>
                <input asp-for="Unit" class="form-control" placeholder="e.g. kg, pc, pack" />
                <span asp-validation-for="Unit" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="CategoryId" class="form-label">Category ID</label>
                <input asp-for="CategoryId" class="form-control" required />
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Create Product</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
