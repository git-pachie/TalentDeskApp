@model CreateProductModel
@{
    ViewData["Title"] = "Add Product";
    var categories = ViewBag.Categories as List<CategoryModel> ?? new List<CategoryModel>();
}

<div class="page-header">
    <div>
        <h2><i class="bi bi-plus-circle-fill me-2 text-primary"></i>Add Product</h2>
        <p class="text-muted mb-0" style="font-size: 0.85rem;">Create a new product in your catalog</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back
    </a>
</div>

<form asp-action="Create" method="post" id="productForm">
    <div class="row g-3">
        <div class="col-lg-8">
            <div class="card form-card mb-3">
                <div class="card-body">
                    <h6 class="fw-bold mb-3"><i class="bi bi-info-circle me-2"></i>Basic Information</h6>
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Product Name</label>
                        <input asp-for="Name" class="form-control" placeholder="e.g. Banana (per kg)" required />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Brief product description..."></textarea>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Unit" class="form-label">Unit</label>
                        <input asp-for="Unit" class="form-control" placeholder="e.g. kg, pcs, pack, bottle" />
                    </div>
                </div>
            </div>

            <div class="card form-card mb-3">
                <div class="card-body">
                    <h6 class="fw-bold mb-3"><i class="bi bi-tag me-2"></i>Pricing & Inventory</h6>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="Price" class="form-label">Price (₱)</label>
                            <input asp-for="Price" class="form-control" type="number" step="0.01" min="0" required />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="DiscountPrice" class="form-label">Discount Price (₱)</label>
                            <input asp-for="DiscountPrice" class="form-control" type="number" step="0.01" min="0" placeholder="Optional" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="StockQuantity" class="form-label">Stock Quantity</label>
                            <input asp-for="StockQuantity" class="form-control" type="number" min="0" required />
                        </div>
                    </div>
                </div>
            </div>

            @* ===== IMAGE UPLOAD ===== *@
            <div class="card form-card mb-3">
                <div class="card-body">
                    <h6 class="fw-bold mb-3"><i class="bi bi-images me-2"></i>Product Images</h6>

                    <div id="dropZone" class="text-center p-4 mb-3 rounded-3"
                         style="border: 2px dashed #d1d5db; background: #f9fafb; cursor: pointer; transition: all 0.2s;">
                        <i class="bi bi-cloud-arrow-up" style="font-size: 2.5rem; color: #9ca3af;"></i>
                        <p class="mb-1 fw-medium" style="color: #6b7280;">Drop images here or click to browse</p>
                        <p class="mb-0 text-muted" style="font-size: 0.8rem;">JPG, PNG, GIF, WebP — max 10 MB each</p>
                        <input type="file" id="fileInput" multiple accept="image/*" class="d-none" />
                    </div>

                    <div id="uploadProgress" class="mb-3 d-none">
                        <div class="progress" style="height: 6px; border-radius: 3px;">
                            <div class="progress-bar bg-primary" id="progressBar" style="width: 0%; transition: width 0.3s;"></div>
                        </div>
                        <small class="text-muted" id="progressText">Uploading...</small>
                    </div>

                    <div id="imagePreviewContainer" class="row g-2"></div>
                    <div id="imageHiddenFields"></div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card form-card mb-3">
                <div class="card-body">
                    <h6 class="fw-bold mb-3"><i class="bi bi-tags me-2"></i>Primary Category</h6>
                    <select asp-for="CategoryId" class="form-select" required>
                        <option value="">Select a category...</option>
                        @foreach (var cat in categories)
                        {
                            <option value="@cat.Id">@cat.Name</option>
                        }
                    </select>
                </div>
            </div>

            <div class="card form-card mb-3">
                <div class="card-body">
                    <h6 class="fw-bold mb-3"><i class="bi bi-collection me-2"></i>Additional Categories</h6>
                    <p class="text-muted" style="font-size: 0.8rem;">Select additional categories this product belongs to.</p>
                    @for (int i = 0; i < categories.Count; i++)
                    {
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" name="CategoryIds" value="@categories[i].Id" id="cat_@i" />
                            <label class="form-check-label" for="cat_@i" style="font-size: 0.875rem;">@categories[i].Name</label>
                        </div>
                    }
                </div>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary py-2" id="submitBtn">
                    <i class="bi bi-check-lg me-1"></i> Create Product
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </div>
    </div>
</form>

@await Html.PartialAsync("_ImageUploadScript")

<script>
    window.imageBaseUrl = '@Html.Raw((string)(ViewBag.ProductImageUrl ?? ""))';
</script>
