@model List<CategoryModel>
@{
    ViewData["Title"] = "Categories";
}

<div class="page-header">
    <div>
        <h2><i class="bi bi-tags-fill me-2 text-primary"></i>Categories</h2>
        <p class="text-muted mb-0" style="font-size: 0.85rem;">Organize your product catalog</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Add Category
    </a>
</div>

<div class="card data-card">
    <table class="table data-table">
        <thead>
            <tr>
                <th>Category</th>
                <th>Description</th>
                <th>Products</th>
                <th>Status</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Count > 0)
            {
                @foreach (var category in Model)
                {
                    <tr>
                        <td class="fw-semibold">@category.Name</td>
                        <td class="text-muted">@(category.Description ?? "—")</td>
                        <td>
                            <span class="badge bg-primary-subtle text-primary rounded-pill">@category.ProductCount</span>
                        </td>
                        <td>
                            @if (category.IsActive)
                            {
                                <span class="badge badge-status bg-success-subtle text-success">Active</span>
                            }
                            else
                            {
                                <span class="badge badge-status bg-secondary-subtle text-secondary">Inactive</span>
                            }
                        </td>
                        <td class="text-end">
                            <form asp-action="Delete" asp-route-id="@category.Id" method="post" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete"
                                        onclick="return confirm('Delete this category?')">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5">
                        <div class="empty-state">
                            <i class="bi bi-tags"></i>
                            <p>No categories found.</p>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
