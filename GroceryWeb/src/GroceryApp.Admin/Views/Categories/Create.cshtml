@model CreateCategoryModel
@{
    ViewData["Title"] = "Add Category";
}

<div class="page-header">
    <div>
        <h2><i class="bi bi-plus-circle-fill me-2 text-primary"></i>Add Category</h2>
        <p class="text-muted mb-0" style="font-size:0.85rem;">Create a new product category</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back
    </a>
</div>

<div class="row">
    <div class="col-lg-6">
        <div class="card form-card">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Emoji</label>
                        <div class="d-flex align-items-center gap-3">
                            <button type="button" id="emojiDisplayBtn"
                                    class="btn btn-outline-secondary"
                                    style="font-size:2rem;width:56px;height:56px;padding:0;border-radius:12px;"
                                    onclick="openEmojiPicker()">
                                @(string.IsNullOrEmpty(Model.Emoji) ? "➕" : Model.Emoji)
                            </button>
                            <span class="text-muted" style="font-size:0.85rem;">Click to pick an emoji for this category</span>
                        </div>
                        <input type="hidden" name="Emoji" id="emojiHiddenInput" value="@Model.Emoji" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold">Category Name <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" placeholder="e.g. Fruits & Vegetables" required />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Brief description..."></textarea>
                    </div>
                    <div class="mb-4">
                        <label asp-for="ImageUrl" class="form-label fw-semibold">Image URL</label>
                        <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-check-lg me-1"></i> Create Category
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("_EmojiPickerModal")

@section Scripts {
<script>
function openEmojiPicker() {
    document.getElementById('emojiSearchInput').value = '';
    document.getElementById('emojiCustomInput').value = '';
    renderEmojiGrid(EMOJIS);
    new bootstrap.Modal(document.getElementById('emojiPickerModal')).show();
}

function onEmojiSelected(emoji) {
    document.getElementById('emojiDisplayBtn').textContent = emoji;
    document.getElementById('emojiHiddenInput').value = emoji;
}
</script>
}
