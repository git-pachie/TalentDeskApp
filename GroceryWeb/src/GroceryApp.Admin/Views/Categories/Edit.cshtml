@model CategoryModel
@{
    ViewData["Title"] = $"Edit — {Model.Name}";
}

<div class="page-header">
    <div>
        <h2><i class="bi bi-pencil-fill me-2 text-primary"></i>Edit Category</h2>
        <p class="text-muted mb-0" style="font-size:0.85rem;">@Model.Name</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back
    </a>
</div>

<div class="row">
    <div class="col-lg-6">
        <div class="card form-card">
            <div class="card-body">
                <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Emoji</label>
                        <div class="d-flex align-items-center gap-3">
                            <button type="button" id="emojiDisplayBtn"
                                    class="btn btn-outline-secondary"
                                    style="font-size:2rem;width:56px;height:56px;padding:0;border-radius:12px;"
                                    onclick="openEmojiPicker()">
                                @(string.IsNullOrEmpty(Model.Emoji) ? "➕" : Model.Emoji)
                            </button>
                            <span class="text-muted" style="font-size:0.85rem;">Click to change the emoji</span>
                        </div>
                        <input type="hidden" name="Emoji" id="emojiHiddenInput" value="@Model.Emoji" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Category Name <span class="text-danger">*</span></label>
                        <input name="Name" class="form-control" value="@Model.Name" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Description</label>
                        <textarea name="Description" class="form-control" rows="3">@Model.Description</textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Image URL</label>
                        <input name="ImageUrl" class="form-control" value="@Model.ImageUrl" placeholder="https://..." />
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Status</label>
                        <select name="IsActive" class="form-select">
                            <option value="true" selected="@(Model.IsActive)">Active</option>
                            <option value="false" selected="@(!Model.IsActive)">Inactive</option>
                        </select>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-check-lg me-1"></i> Save Changes
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("_EmojiPickerModal")

@section Scripts {
<script>
function openEmojiPicker() {
    document.getElementById('emojiSearchInput').value = '';
    document.getElementById('emojiCustomInput').value = '';
    renderEmojiGrid(EMOJIS);
    new bootstrap.Modal(document.getElementById('emojiPickerModal')).show();
}

function onEmojiSelected(emoji) {
    document.getElementById('emojiDisplayBtn').textContent = emoji;
    document.getElementById('emojiHiddenInput').value = emoji;
}
</script>
}
